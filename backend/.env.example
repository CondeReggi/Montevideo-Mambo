# Variables de entorno del backend (.NET). Copiar a appsettings.Development.json
# o exportar como variables de entorno. NO commitear valores reales.

# Cadena de conexión a Supabase PostgreSQL (usar el connection pooler de Supabase)
ConnectionStrings__Supabase=Host=db.<proyecto>.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=<password>;SSL Mode=Require;Trust Server Certificate=true

# Identidad / validación de JWT de Supabase Auth
Supabase__Url=https://<proyecto>.supabase.co
Supabase__JwtSecret=<jwt-secret-del-proyecto>     # firma HS256 de Supabase
Supabase__ServiceRoleKey=<service-role-key>        # SOLO backend, secreto
Supabase__AnonKey=<anon-key>

# Storage
Supabase__StorageBucketPhotos=student-photos
Supabase__StorageBucketQr=qr-prints

# CORS (orígenes del frontend separados por ;)
Cors__Origins=http://localhost:3000
